{
  "name": "me-corp",
  "version": "1.0.0",
  "private": true,
  "description": "Me Corp - 个人公司化管理系统",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:server": "npm run dev --workspace=packages/server",
    "build": "npm run build --workspace=packages/client"
  },
  "dependencies": {
    "mammoth": "^1.11.0",
    "multer": "^2.1.0",
    "pdf-parse": "^2.4.5"
  }
}
